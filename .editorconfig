# top-most EditorConfig file
root = true

# Default settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript / TypeScript / JSON / CSS / HTML
[*.{js,ts,jsx,tsx,json,css,scss,html}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.yml]
indent_size = 2

# Python (future-proof if needed)
[*.py]
indent_size = 4
